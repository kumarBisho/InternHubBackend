# =============================================================
# DATABASE CONFIGURATION
# =============================================================
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=InternMsDB;Username=postgres;Password=YOUR_PASSWORD

# =============================================================
# JWT CONFIGURATION
# =============================================================
# IMPORTANT: Generate a strong JWT key (minimum 256 bits / 32 bytes)
# Use the following PowerShell command to generate:
# [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JWT_SECRET_KEY=GENERATE_STRONG_KEY_MIN_256_BITS

# =============================================================
# FRONTEND CONFIGURATION
# =============================================================
FRONTEND_URL=http://localhost:5173

# =============================================================
# ASPNETCORE CONFIGURATION
# =============================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# =============================================================
# LOGGING CONFIGURATION
# =============================================================
LOG_LEVEL=Information

# =============================================================
# CORS CONFIGURATION
# =============================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
